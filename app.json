{
  "name": "to-do-list",
  "description": "CRM система для анализа продаж",
  "keywords": ["symfony", "php", "crm", "postgresql"],
  "repository": "https://github.com/your-username/to-do-list",
  "success_url": "/",
  "stack": "container",
  "env": {
    "APP_ENV": {
      "description": "Application environment",
      "value": "prod"
    },
    "APP_SECRET": {
      "description": "Application secret key",
      "generator": "secret"
    },
    "DATABASE_URL": {
      "description": "PostgreSQL database URL"
    },
    "REDIS_URL": {
      "description": "Redis URL"
    },
    "MAILER_DSN": {
      "description": "Mailer DSN",
      "value": "smtp://localhost:1025"
    },
    "MAILER_FROM_EMAIL": {
      "description": "From email for mailer",
      "value": "noreply@example.com"
    },
    "MAILER_FROM_NAME": {
      "description": "From name for mailer",
      "value": "To-Do List"
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "standard-1x"
    }
  },
  "addons": [
    { "plan": "heroku-postgresql:mini" },
    { "plan": "heroku-redis:mini" }
  ],
  "buildpacks": [
    { "url": "heroku/docker" }
  ],
  "scripts": {
    "postdeploy": "php bin/console doctrine:migrations:migrate --no-interaction"
  }
}
