# GitHub Actions Secrets Template
# Скопируйте этот файл в .github/secrets.example и заполните своими значениями
# Затем добавьте секреты в GitHub: Settings → Secrets and variables → Actions

# ===========================================
# Amvera Cloud
# ===========================================
# AMVERA_TOKEN=your_amvera_api_token
# AMVERA_PROJECT_ID=your_project_id
# AMVERA_DOMAIN=your-domain.amvera.app

# ===========================================
# Railway
# ===========================================
# RAILWAY_TOKEN=your_railway_api_token
# RAILWAY_ENVIRONMENT_ID=your_environment_id
# RAILWAY_DOMAIN=your-domain.railway.app

# ===========================================
# Render
# ===========================================
# RENDER_API_KEY=your_render_api_key
# RENDER_SERVICE_ID=your_service_id

# ===========================================
# Fly.io
# ===========================================
# FLY_API_TOKEN=your_fly_api_token

# ===========================================
# Heroku
# ===========================================
# HEROKU_API_KEY=your_heroku_api_key
# HEROKU_EMAIL=your_heroku_email
# HEROKU_APP_NAME=your_app_name

# ===========================================
# Переменные окружения приложения
# ===========================================
# APP_SECRET=your_32_character_secret_key
# DATABASE_URL=postgresql://user:password@host:5432/database
# REDIS_URL=redis://host:6379
# MAILER_DSN=smtp://username:password@smtp.example.com:587
# MAILER_FROM_EMAIL=noreply@example.com
# MAILER_FROM_NAME="To-Do List"
