{% extends 'base.html.twig' %}

{% block title %}Клиенты{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link rel="stylesheet" href="{{ asset('css/pages/clients.css') }}">
{% endblock %}

{% block body %}
{{ include('components/breadcrumbs.html.twig', {
    items: [
        {label: 'Главная', url: path('app_dashboard')},
        {label: 'Клиенты', active: true}
    ]
}) }}

<div class="container-fluid py-4 animate-fade-in">
    <div class="page-header stagger-item mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h1 class="mb-1">
                    <i class="fas fa-users me-2 text-primary"></i>
                    Клиенты
                </h1>
                <p class="mb-0 opacity-75">Управление базой клиентов и партнёров</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <button class="btn btn-outline-secondary btn-modern" data-bs-toggle="modal" data-bs-target="#exportModal">
                    <i class="fas fa-download me-2"></i>
                    Экспорт
                </button>
                <a href="{{ path('app_clients_new') }}" class="btn btn-gradient-primary">
                    <i class="fas fa-plus me-2"></i>
                    Добавить клиента
                </a>
            </div>
        </div>
    </div>

    {% if clients is not empty %}
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-md-6">
                <div class="stat-card stat-card-primary stagger-item delay-100">
                    <div class="stat-icon bg-primary bg-opacity-10 text-primary">
                        <i class="fas fa-users"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{ clients|length }}</div>
                        <div class="stat-label">Всего клиентов</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card stat-card-success stagger-item delay-200">
                    <div class="stat-icon bg-success bg-opacity-10 text-success">
                        <i class="fas fa-crown"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{ clients|filter(c => c.category == 'vip')|length }}</div>
                        <div class="stat-label">VIP клиенты</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card stat-card-warning stagger-item delay-300">
                    <div class="stat-icon bg-warning bg-opacity-10 text-warning">
                        <i class="fas fa-star"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{ clients|filter(c => c.category == 'new')|length }}</div>
                        <div class="stat-label">Новые</div>
                    </div>
                </div>
            </div>
            <div class="col-xl-3 col-md-6">
                <div class="stat-card stat-card-info stagger-item delay-400">
                    <div class="stat-icon bg-info bg-opacity-10 text-info">
                        <i class="fas fa-boxes"></i>
                    </div>
                    <div class="stat-content">
                        <div class="stat-number">{{ clients|filter(c => c.segment == 'wholesale')|length }}</div>
                        <div class="stat-label">Оптовые</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card card-modern mb-4">
            <div class="card-header-modern">
                <i class="fas fa-filter me-2"></i>
                Фильтры и поиск
            </div>
            <div class="card-body-modern">
                <div class="row g-3">
                    <div class="col-lg-6">
                        <div class="search-input-group">
                            <i class="fas fa-search search-icon"></i>
                            <input type="text" class="form-control" id="searchInput" placeholder="Поиск по названию, контакту, email...">
                        </div>
                    </div>
                    <div class="col-lg-3">
                        <select class="form-select" id="segmentFilter">
                            <option value="">Все сегменты</option>
                            <option value="wholesale">📦 Опт</option>
                            <option value="retail">🛒 Розница</option>
                        </select>
                    </div>
                    <div class="col-lg-3">
                        <select class="form-select" id="categoryFilter">
                            <option value="">Все категории</option>
                            <option value="new">⭐ Новый</option>
                            <option value="regular">✓ Постоянный</option>
                            <option value="vip">👑 VIP</option>
                            <option value="potential">💡 Потенциальный</option>
                        </select>
                    </div>
                </div>
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted small">
                        <span id="visibleCount">{{ clients|length }}</span> из {{ clients|length }} клиентов
                    </div>
                    <button class="btn btn-sm btn-outline-secondary" id="resetFilters">
                        <i class="fas fa-times me-1"></i>
                        Сбросить
                    </button>
                </div>
            </div>
        </div>

        <div class="row g-3" id="clientsList">
            {% for client in clients %}
                <div class="col-lg-6 col-xl-4">
                    <div class="client-card-modern h-100"
                         data-company="{{ client.companyName|lower }}"
                         data-contact="{{ client.contactPerson|default('')|lower }}"
                         data-email="{{ client.email|default('')|lower }}"
                         data-segment="{{ client.segment }}"
                         data-category="{{ client.category }}">
                        <div class="client-card-header">
                            <div class="client-avatar-modern">
                                {{ client.companyName|slice(0, 2)|upper }}
                            </div>
                            <div class="client-actions">
                                <a href="{{ path('app_clients_show', {id: client.id}) }}" class="btn-action btn-action-info" title="Просмотр">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a href="{{ path('app_clients_edit', {id: client.id}) }}" class="btn-action btn-action-warning" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <button class="btn-action btn-action-danger" onclick="deleteClient({{ client.id }})" title="Удалить">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        <div class="client-card-body">
                            <h5 class="client-title">
                                <a href="{{ path('app_clients_show', {id: client.id}) }}" class="text-decoration-none">
                                    {{ client.companyName }}
                                </a>
                            </h5>
                            <div class="client-contact">
                                {% if client.contactPerson %}
                                    <div class="contact-item">
                                        <i class="fas fa-user"></i>
                                        <span>{{ client.contactPerson }}</span>
                                    </div>
                                {% endif %}
                                {% if client.phone %}
                                    <div class="contact-item">
                                        <i class="fas fa-phone"></i>
                                        <a href="tel:{{ client.phone }}">{{ client.phone }}</a>
                                    </div>
                                {% endif %}
                                {% if client.email %}
                                    <div class="contact-item">
                                        <i class="fas fa-envelope"></i>
                                        <a href="mailto:{{ client.email }}">{{ client.email }}</a>
                                    </div>
                                {% endif %}
                            </div>
                            <div class="client-badges">
                                <span class="badge badge-segment badge-{{ client.segment == 'wholesale' ? 'primary' : 'secondary' }}">
                                    <i class="fas fa-{{ client.segment == 'wholesale' ? 'boxes' : 'shopping-cart' }}"></i>
                                    {{ client.segment == 'wholesale' ? 'Опт' : 'Розница' }}
                                </span>
                                <span class="badge badge-category badge-{{ client.category }}">
                                    <i class="fas fa-{{ client.category == 'vip' ? 'crown' : (client.category == 'new' ? 'star' : (client.category == 'regular' ? 'check-circle' : 'lightbulb')) }}"></i>
                                    {% if client.category == 'new' %}Новый
                                    {% elseif client.category == 'regular' %}Постоянный
                                    {% elseif client.category == 'vip' %}VIP
                                    {% else %}Потенциальный{% endif %}
                                </span>
                            </div>
                            {% if client.lastContactAt %}
                                <div class="client-last-contact">
                                    <i class="fas fa-clock"></i>
                                    Последнее касание: {{ client.lastContactAt|date('d.m.Y') }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <div class="empty-state text-center py-5 d-none" id="emptyState">
            <div class="empty-icon">
                <i class="fas fa-search"></i>
            </div>
            <h4>Ничего не найдено</h4>
            <p class="text-muted">Попробуйте изменить параметры поиска или фильтры</p>
            <button class="btn btn-outline-primary" id="resetFilters2">
                <i class="fas fa-redo me-2"></i>
                Сбросить фильтры
            </button>
        </div>
    {% else %}
        {{ include('components/empty_state.html.twig', {
            icon: 'fa-users',
            title: 'Нет клиентов',
            message: 'Создайте первого клиента для начала работы',
            action_url: path('app_clients_new'),
            action_text: 'Добавить клиента'
        }) }}
    {% endif %}
</div>

{% if clients is not empty %}
<div class="modal fade" id="exportModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-download me-2"></i>Экспорт клиентов</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="d-grid gap-2">
                    <a href="{{ path('app_export_tasks_csv') }}" class="btn btn-outline-success">
                        <i class="fas fa-file-csv me-2"></i>
                        Экспорт в CSV
                    </a>
                    <a href="{{ path('app_export_tasks_excel') }}" class="btn btn-outline-success">
                        <i class="fas fa-file-excel me-2"></i>
                        Экспорт в Excel
                    </a>
                    <a href="{{ path('app_export_tasks_pdf') }}" class="btn btn-outline-danger">
                        <i class="fas fa-file-pdf me-2"></i>
                        Экспорт в PDF
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<form id="deleteForm" method="post" style="display: none;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete') }}">
</form>
{% endif %}

<script>
function deleteClient(id) {
    if (confirm('Вы уверены, что хотите удалить этого клиента?')) {
        const form = document.getElementById('deleteForm');
        form.action = '/clients/' + id + '/delete';
        form.submit();
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const segmentFilter = document.getElementById('segmentFilter');
    const categoryFilter = document.getElementById('categoryFilter');
    const resetFilters = document.getElementById('resetFilters');
    const resetFilters2 = document.getElementById('resetFilters2');
    const clientCards = document.querySelectorAll('.client-card-modern');
    const visibleCountEl = document.getElementById('visibleCount');
    const emptyState = document.getElementById('emptyState');
    const clientsList = document.getElementById('clientsList');

    function filterClients() {
        const searchTerm = searchInput ? searchInput.value.toLowerCase().trim() : '';
        const selectedSegment = segmentFilter ? segmentFilter.value : '';
        const selectedCategory = categoryFilter ? categoryFilter.value : '';

        let visibleCount = 0;

        clientCards.forEach(card => {
            const company = card.dataset.company || '';
            const contact = card.dataset.contact || '';
            const email = card.dataset.email || '';
            const segment = card.dataset.segment || '';
            const category = card.dataset.category || '';

            const matchesSearch = !searchTerm ||
                company.includes(searchTerm) ||
                contact.includes(searchTerm) ||
                email.includes(searchTerm);

            const matchesSegment = !selectedSegment || segment === selectedSegment;
            const matchesCategory = !selectedCategory || category === selectedCategory;

            if (matchesSearch && matchesSegment && matchesCategory) {
                card.closest('.col-lg-6')?.style.display = '';
                visibleCount++;
            } else {
                card.closest('.col-lg-6')?.style.display = 'none';
            }
        });

        if (visibleCountEl) {
            visibleCountEl.textContent = visibleCount;
        }

        if (visibleCount === 0) {
            clientsList?.classList.add('d-none');
            emptyState?.classList.remove('d-none');
        } else {
            clientsList?.classList.remove('d-none');
            emptyState?.classList.add('d-none');
        }
    }

    function resetFilters() {
        if (searchInput) searchInput.value = '';
        if (segmentFilter) segmentFilter.value = '';
        if (categoryFilter) categoryFilter.value = '';
        filterClients();
    }

    if (searchInput) searchInput.addEventListener('input', filterClients);
    if (segmentFilter) segmentFilter.addEventListener('change', filterClients);
    if (categoryFilter) categoryFilter.addEventListener('change', filterClients);
    if (resetFilters) resetFilters.addEventListener('click', resetFilters);
    if (resetFilters2) resetFilters2.addEventListener('click', resetFilters);
});
</script>
{% endblock %}
