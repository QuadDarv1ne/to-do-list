{# templates/errors/404.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Страница не найдена - 404 | CRM система{% endblock %}

{% block meta_description %}Запрашиваемая страница не найдена. Вернитесь на главную или воспользуйтесь поиском.{% endblock %}

{% block stylesheets %}
<style>
    .error-page {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        padding: 2rem;
    }
    
    .error-content {
        text-align: center;
        color: white;
        max-width: 600px;
    }
    
    .error-code {
        font-size: 10rem;
        font-weight: 900;
        line-height: 1;
        margin-bottom: 1rem;
        text-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
        animation: float 3s ease-in-out infinite;
    }
    
    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
    
    .error-message {
        font-size: 1.5rem;
        margin-bottom: 1rem;
        opacity: 0.95;
    }
    
    .error-description {
        font-size: 1.1rem;
        margin-bottom: 2rem;
        opacity: 0.85;
        line-height: 1.6;
    }
    
    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .btn-error {
        padding: 1rem 2rem;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .btn-error-primary {
        background: white;
        color: #667eea;
    }
    
    .btn-error-primary:hover {
        background: #f8fafc;
        transform: translateY(-2px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    }
    
    .btn-error-secondary {
        background: rgba(255, 255, 255, 0.2);
        color: white;
        border: 2px solid rgba(255, 255, 255, 0.3);
    }
    
    .btn-error-secondary:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: translateY(-2px);
    }
    
    .error-icon {
        font-size: 4rem;
        margin-bottom: 2rem;
        opacity: 0.9;
    }
    
    .search-box {
        margin-top: 2rem;
        background: rgba(255, 255, 255, 0.15);
        padding: 0.5rem;
        border-radius: 50px;
        display: flex;
        backdrop-filter: blur(10px);
    }
    
    .search-box input {
        flex: 1;
        border: none;
        background: transparent;
        padding: 0.75rem 1.5rem;
        color: white;
        font-size: 1rem;
        outline: none;
    }
    
    .search-box input::placeholder {
        color: rgba(255, 255, 255, 0.7);
    }
    
    .search-box button {
        background: white;
        color: #667eea;
        border: none;
        padding: 0.75rem 1.5rem;
        border-radius: 50px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
    }
    
    .search-box button:hover {
        transform: scale(1.05);
    }
    
    .quick-links {
        margin-top: 2rem;
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        flex-wrap: wrap;
    }
    
    .quick-links a {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: none;
        padding: 0.5rem 1rem;
        border-radius: 8px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .quick-links a:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }
    
    @media (max-width: 640px) {
        .error-code {
            font-size: 6rem;
        }
        
        .error-message {
            font-size: 1.25rem;
        }
        
        .error-actions {
            flex-direction: column;
        }
        
        .btn-error {
            width: 100%;
            justify-content: center;
        }
    }
</style>
{% endblock %}

{% block body %}
<div class="error-page">
    <div class="error-content">
        <div class="error-icon">
            <i class="fas fa-search-location"></i>
        </div>
        
        <div class="error-code">404</div>
        
        <h1 class="error-message">Упс! Страница не найдена</h1>
        
        <p class="error-description">
            Похоже, вы перешли по ссылке, которая ведёт на несуществующую страницу.
            Возможно, она была удалена или перемещена.
        </p>
        
        <div class="error-actions">
            <a href="{{ path('app_dashboard') }}" class="btn-error btn-error-primary">
                <i class="fas fa-home"></i>
                Вернуться на главную
            </a>
            <a href="{{ path('app_task_index') }}" class="btn-error btn-error-secondary">
                <i class="fas fa-tasks"></i>
                Перейти к задачам
            </a>
        </div>
        
        <form action="{{ path('app_search') }}" method="get" class="search-box">
            <input type="text" name="q" placeholder="Поиск по сайту...">
            <button type="submit">
                <i class="fas fa-search"></i>
            </button>
        </form>
        
        <div class="quick-links">
            <a href="{{ path('app_calendar') }}">
                <i class="fas fa-calendar"></i>
                Календарь
            </a>
            <a href="{{ path('app_kanban_index') }}">
                <i class="fas fa-columns"></i>
                Канбан
            </a>
            <a href="{{ path('app_clients_index') }}">
                <i class="fas fa-users"></i>
                Клиенты
            </a>
            <a href="{{ path('app_deals_index') }}">
                <i class="fas fa-handshake"></i>
                Сделки
            </a>
            <a href="{{ path('app_reports') }}">
                <i class="fas fa-chart-bar"></i>
                Отчёты
            </a>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
    // Убираем лоадер, если он есть
    document.addEventListener('DOMContentLoaded', function() {
        const loader = document.querySelector('.page-loader');
        if (loader) {
            loader.classList.add('hidden');
        }
        document.body.classList.add('loaded');
    });
</script>
{% endblock %}
