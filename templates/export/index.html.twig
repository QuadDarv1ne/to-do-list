{% extends 'base.html.twig %}

{% block title %}Экспорт данных{% endblock %}

{% block stylesheets %}
<style>
    .export-container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
    .export-header { text-align: center; margin-bottom: 3rem; }
    .export-header h1 { font-size: 2.5rem; color: #2c3e50; margin-bottom: 0.5rem; }
    .export-header p { color: #7f8c8d; font-size: 1.1rem; }
    .formats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem; margin-bottom: 3rem; }
    .format-card { 
        background: white; 
        border-radius: 12px; 
        padding: 2rem; 
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
        border: 2px solid transparent;
    }
    .format-card:hover { 
        transform: translateY(-5px); 
        box-shadow: 0 8px 25px rgba(0,0,0,0.15);
        border-color: #4F81BD;
    }
    .format-icon { font-size: 3rem; margin-bottom: 1rem; }
    .format-name { font-size: 1.5rem; font-weight: 600; color: #2c3e50; margin-bottom: 0.5rem; }
    .format-description { color: #7f8c8d; margin-bottom: 1.5rem; }
    .format-features { list-style: none; padding: 0; margin-bottom: 1.5rem; }
    .format-features li { padding: 0.5rem 0; color: #34495e; }
    .format-features li:before { content: "✓ "; color: #27ae60; font-weight: bold; margin-right: 0.5rem; }
    .btn-export { 
        width: 100%; 
        padding: 0.75rem; 
        border: none; 
        border-radius: 8px; 
        background: #4F81BD; 
        color: white; 
        font-size: 1rem; 
        font-weight: 600;
        cursor: pointer;
        transition: background 0.3s;
    }
    .btn-export:hover { background: #3a6b9a; }
    .filters-section { 
        background: white; 
        border-radius: 12px; 
        padding: 2rem; 
        margin-bottom: 2rem;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    .filters-section h2 { margin-bottom: 1.5rem; color: #2c3e50; }
    .filters-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; }
    .filter-group { margin-bottom: 1rem; }
    .filter-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; color: #34495e; }
    .filter-group select, .filter-group input { 
        width: 100%; 
        padding: 0.75rem; 
        border: 1px solid #ddd; 
        border-radius: 6px; 
        font-size: 1rem;
    }
    .stats-section { 
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); 
        border-radius: 12px; 
        padding: 2rem; 
        color: white;
        margin-bottom: 2rem;
    }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1.5rem; }
    .stat-item { text-align: center; }
    .stat-value { font-size: 2.5rem; font-weight: 700; margin-bottom: 0.5rem; }
    .stat-label { font-size: 0.9rem; opacity: 0.9; }
    .alert { padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; }
    .alert-info { background: #e3f2fd; border-left: 4px solid #2196F3; color: #1976D2; }
</style>
{% endblock %}

{% block body %}
<div class="export-container">
    <div class="export-header">
        <h1>📤 Экспорт данных</h1>
        <p>Выгрузите ваши данные в удобном формате для отчётности или резервного копирования</p>
    </div>

    {# Статистика #}
    <div class="stats-section">
        <h2 style="margin-bottom: 1.5rem;">📊 Ваша статистика</h2>
        <div class="stats-grid" id="stats-grid">
            <div class="stat-item">
                <div class="stat-value" id="stat-total">-</div>
                <div class="stat-label">Всего задач</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-completed">-</div>
                <div class="stat-label">Завершено</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-pending">-</div>
                <div class="stat-label">В ожидании</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-rate">-</div>
                <div class="stat-label">Процент выполнения</div>
            </div>
        </div>
    </div>

    {# Фильтры #}
    <div class="filters-section">
        <h2>🔍 Фильтры экспорта</h2>
        <form id="export-filters">
            <div class="filters-grid">
                <div class="filter-group">
                    <label for="filter-status">Статус</label>
                    <select name="status" id="filter-status">
                        <option value="">Все статусы</option>
                        <option value="pending">В ожидании</option>
                        <option value="in_progress">В работе</option>
                        <option value="completed">Завершено</option>
                        <option value="cancelled">Отменено</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filter-priority">Приоритет</label>
                    <select name="priority" id="filter-priority">
                        <option value="">Все приоритеты</option>
                        <option value="low">Низкий</option>
                        <option value="medium">Средний</option>
                        <option value="high">Высокий</option>
                        <option value="urgent">Срочно</option>
                    </select>
                </div>
                <div class="filter-group">
                    <label for="filter-search">Поиск</label>
                    <input type="text" name="search" id="filter-search" placeholder="Поиск по названию...">
                </div>
            </div>
        </form>
    </div>

    <div class="alert alert-info">
        💡 <strong>Совет:</strong> Выберите фильтры перед экспортом, чтобы выгрузить только нужные данные.
    </div>

    {# Форматы экспорта #}
    <div class="formats-grid">
        {% for format in formats %}
        <div class="format-card">
            <div class="format-icon">{{ format.icon }}</div>
            <div class="format-name">{{ format.name }}</div>
            <div class="format-description">{{ format.description }}</div>
            <ul class="format-features">
                {% if format.id == 'csv' %}
                    <li>Быстрое открытие в Excel</li>
                    <li>Разделитель — точка с запятой</li>
                    <li>Кодировка UTF-8</li>
                {% elseif format.id == 'excel' %}
                    <li>Полное форматирование</li>
                    <li>Цветовая индикация статусов</li>
                    <li>Авто-ширина колонок</li>
                {% elseif format.id == 'json' %}
                    <li>Структурированный формат</li>
                    <li>Для интеграций и API</li>
                    <li>Читаемый человеком</li>
                {% elseif format.id == 'pdf' %}
                    <li>Готово к печати</li>
                    <li>Красивая статистика</li>
                    <li>Профессиональный вид</li>
                {% endif %}
            </ul>
            <button class="btn-export" data-format="{{ format.id }}">
                Экспортировать в {{ format.name }}
            </button>
        </div>
        {% endfor %}
    </div>
</div>

<script>
// Загрузка статистики
document.addEventListener("DOMContentLoaded", function() {
    fetch("{{ path("export_statistics") }}")
        .then(r => r.json())
        .then(data => {
            if (data.success && data.data) {
                document.getElementById("stat-total").textContent = data.data.total_tasks;
                document.getElementById("stat-completed").textContent = data.data.completed;
                document.getElementById("stat-pending").textContent = data.data.pending;
                document.getElementById("stat-rate").textContent = data.data.completion_rate + "%";
            }
        });

    // Обработчики кнопок экспорта
    document.querySelectorAll(".btn-export").forEach(btn => {
        btn.addEventListener("click", function() {
            const format = this.dataset.format;
            const filtersForm = document.getElementById("export-filters");
            const filters = filtersForm ? new FormData(filtersForm) : new FormData();

            let params = new URLSearchParams();
            for (let [key, value] of filters.entries()) {
                if (value) params.append(key, value);
            }

            const url = `/export/tasks/${format}?${params.toString()}`;
            window.location.href = url;
        });
    });
});
</script>
{% endblock %}
